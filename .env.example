# Copy to .env and fill in. All optional — sources that need a key return empty
# without one; everything else is keyless. .env is gitignored.

# Wikipedia/archive User-Agent contact (email or URL), per Wikimedia policy.
FORECAST_CONTACT=you@example.com

# FRED economic data — free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# NOAA weather — free token: https://www.ncdc.noaa.gov/cdo-web/token
NOAA_TOKEN=

# GDELT BigQuery backend (optional; only if using GDELTNewsSource(backend="bigquery")).
# Auth keylessly with:  gcloud auth application-default login
# Then set just your project id below. (A service-account JSON key via
# GOOGLE_APPLICATION_CREDENTIALS also works if your org allows key creation.)
# Leave blank to use the default keyless rawfiles backend.
GOOGLE_CLOUD_PROJECT=
